{
  "version": 2,
  "builds": [
    {
      "src": "habit-tracker/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/habit-tracker/$1"
    }
  ],
  "buildCommand": "cd habit-tracker && npm run build",
  "outputDirectory": "habit-tracker/build",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
